    "cloud_auth.error.transport.send_code_interrupted" : {
      "comment" : "Cloud auth inline error when the network connection drops while sending the OTP code",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "انقطع الاتصال أثناء إرسال الرمز. تحقّق من بريدك الإلكتروني، ثم حاول مرة أخرى إذا لزم الأمر."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Verbindung wurde beim Senden des Codes unterbrochen. Prüfe deine E-Mails und versuche es bei Bedarf erneut."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The connection was interrupted while sending the code. Check your email, then try again if needed."
          }
        },
        "es-ES" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La conexión se interrumpió mientras se enviaba el código. Revisa tu correo y, si hace falta, vuelve a intentarlo."
          }
        },
        "es-MX" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La conexión se interrumpió mientras se enviaba el código. Revisa tu correo y, si hace falta, vuelve a intentarlo."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "कोड भेजते समय कनेक्शन बाधित हो गया। अपना ईमेल जाँचें, फिर ज़रूरत हो तो दोबारा कोशिश करें।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "コードの送信中に接続が中断されました。メールを確認し、必要に応じてもう一度お試しください。"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Соединение прервалось во время отправки кода. Проверьте почту, затем при необходимости попробуйте еще раз."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "发送验证码时连接中断。请先检查你的邮箱，如有需要再重试。"
          }
        }
      }
    },
    "cloud_auth.error.transport.verify_code_interrupted" : {
