    "access_permission_guidance.allowed" : {
      "comment" : "Guidance when permission is allowed",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "إذا أردت إيقاف هذا الوصول، فافتح الإعدادات."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Öffne die Einstellungen, wenn du diesen Zugriff deaktivieren möchtest."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Open Settings if you want to turn this access off."
          }
        },
        "es-ES" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abre Ajustes si quieres desactivar este acceso."
          }
        },
        "es-MX" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abre Ajustes si quieres desactivar este acceso."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "अगर आप यह एक्सेस बंद करना चाहते हैं, तो सेटिंग्स खोलें।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このアクセスをオフにするには、「設定」を開いてください。"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Откройте «Настройки», если хотите отключить этот доступ."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "如果你想关闭此访问权限，请打开“设置”。"
          }
        }
      }
    },
    "access_permission_guidance.ask_every_time" : {
      "comment" : "Guidance when permission has not been requested yet",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اطلب الوصول الآن، أو افتح الإعدادات لاحقًا إذا أردت إدارته يدويًا."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fordere den Zugriff jetzt an oder öffne später die Einstellungen, wenn du ihn manuell verwalten möchtest."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Request access now, or open Settings later if you want to manage it manually."
          }
        },
        "es-ES" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Solicita acceso ahora o abre Ajustes más tarde si quieres gestionarlo manualmente."
          }
        },
        "es-MX" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Solicita acceso ahora o abre Ajustes más tarde si quieres gestionarlo manualmente."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "अभी एक्सेस माँगें, या यदि आप इसे मैन्युअल रूप से प्रबंधित करना चाहते हैं तो बाद में सेटिंग्स खोलें।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "今すぐアクセスをリクエストするか、手動で管理したい場合は後で「設定」を開いてください。"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Запросите доступ сейчас или позже откройте «Настройки», если хотите управлять им вручную."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "现在请求访问权限，或者稍后打开“设置”手动管理。"
          }
        }
      }
    },
    "access_permission_guidance.camera.blocked" : {
      "comment" : "Guidance when camera permission is blocked",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تم إيقاف الوصول إلى الكاميرا لتطبيق Flashcards Open Source App. افتح الإعدادات > الخصوصية والأمان > الكاميرا لتغييره."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Kamerazugriff für Flashcards Open Source App ist deaktiviert. Öffne Einstellungen > Datenschutz und Sicherheit > Kamera, um das zu ändern."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Camera access is turned off for Flashcards Open Source App. Open Settings > Privacy & Security > Camera to change it."
          }
        },
        "es-ES" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El acceso a la cámara está desactivado para Flashcards Open Source App. Abre Ajustes > Privacidad y seguridad > Cámara para cambiarlo."
          }
        },
        "es-MX" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El acceso a la cámara está desactivado para Flashcards Open Source App. Abre Ajustes > Privacidad y seguridad > Cámara para cambiarlo."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Flashcards Open Source App के लिए कैमरा एक्सेस बंद है। इसे बदलने के लिए सेटिंग्स > गोपनीयता और सुरक्षा > कैमरा खोलें।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Flashcards Open Source App のカメラへのアクセスはオフです。変更するには「設定」>「プライバシーとセキュリティ」>「カメラ」を開いてください。"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Доступ к камере для Flashcards Open Source App отключен. Чтобы изменить это, откройте «Настройки» > «Конфиденциальность и безопасность» > «Камера»."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Flashcards Open Source App 的相机访问权限已关闭。打开“设置”>“隐私与安全性”>“相机”进行更改。"
          }
        }
      }
    },
