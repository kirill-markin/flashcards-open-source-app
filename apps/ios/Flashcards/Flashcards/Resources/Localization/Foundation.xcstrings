        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La conexión se interrumpió mientras se enviaba el código. Revisa tu correo y, si hace falta, vuelve a intentarlo."
          }
        }
      }
    },
    "cloud_auth.error.transport.verify_code_interrupted" : {
