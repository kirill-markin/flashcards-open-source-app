    "transient_banner.ai_chat_active_run" : {
      "comment" : "Banner message when an AI response is already in progress",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "هناك رد جارٍ بالفعل. انتظر حتى ينتهي أو أوقِفه قبل إرسال رسالة أخرى."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eine Antwort wird bereits erstellt. Warte, bis sie fertig ist, oder stoppe sie, bevor du eine weitere Nachricht sendest."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A response is already in progress. Wait for it to finish or stop it before sending another message."
          }
        },
        "es-ES" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ya hay una respuesta en curso. Espera a que termine o detenla antes de enviar otro mensaje."
          }
        },
        "es-MX" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ya hay una respuesta en curso. Espera a que termine o detenla antes de enviar otro mensaje."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "एक जवाब पहले से जारी है। उसके पूरा होने तक प्रतीक्षा करें या दूसरा संदेश भेजने से पहले उसे रोकें।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "すでに応答を生成中です。完了するまで待つか、停止してから別のメッセージを送信してください。"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ответ уже создается. Дождитесь завершения или остановите его перед отправкой другого сообщения."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "已有回复正在生成中。请等待其完成，或先停止它再发送另一条消息。"
          }
        }
      }
    },
    "transient_banner.ai_chat_offline" : {
