    "Delete this card?":{"extractionState":"manual","localizations":{"en":{"stringUnit":{"state":"translated","value":"Delete this card?"}},"ar":{"stringUnit":{"state":"translated","value":"هل تريد حذف هذه البطاقة؟"}},"zh-Hans":{"stringUnit":{"state":"translated","value":"删除这张卡片？"}},"de":{"stringUnit":{"state":"translated","value":"Diese Karte löschen?"}},"hi":{"stringUnit":{"state":"translated","value":"क्या इस कार्ड को हटाना है?"}},"ja":{"stringUnit":{"state":"translated","value":"このカードを削除しますか？"}},"ru":{"stringUnit":{"state":"translated","value":"Удалить эту карточку?"}},"es-MX":{"stringUnit":{"state":"translated","value":"¿Eliminar esta tarjeta?"}},"es-ES":{"stringUnit":{"state":"translated","value":"¿Eliminar esta tarjeta?"}}}},
    "Deleting removes this card from the local list and from the next sync.":{"extractionState":"manual","localizations":{"en":{"stringUnit":{"state":"translated","value":"Deleting removes this card from the local list and from the next sync."}},"ar":{"stringUnit":{"state":"translated","value":"سيؤدي الحذف إلى إزالة هذه البطاقة من القائمة المحلية ومن المزامنة التالية."}},"zh-Hans":{"stringUnit":{"state":"translated","value":"删除后，这张卡片会从本地列表中移除，并在下次同步时删除。"}},"de":{"stringUnit":{"state":"translated","value":"Durch das Löschen wird diese Karte aus der lokalen Liste und aus der nächsten Synchronisierung entfernt."}},"hi":{"stringUnit":{"state":"translated","value":"हटाने पर यह कार्ड स्थानीय सूची और अगली सिंक, दोनों से हट जाएगा।"}},"ja":{"stringUnit":{"state":"translated","value":"削除すると、このカードはローカル一覧から削除され、次回の同期対象からも外れます。"}},"ru":{"stringUnit":{"state":"translated","value":"При удалении карточка будет убрана из локального списка и из следующей синхронизации."}},"es-MX":{"stringUnit":{"state":"translated","value":"Al eliminarla, esta tarjeta se quita de la lista local y de la próxima sincronización."}},"es-ES":{"stringUnit":{"state":"translated","value":"Al eliminarla, esta tarjeta se quita de la lista local y de la próxima sincronización."}}}},
