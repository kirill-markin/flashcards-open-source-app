    "This review filter does not include any cards yet.":{"extractionState":"manual","localizations":{"en":{"stringUnit":{"state":"translated","value":"This review filter does not include any cards yet."}},"ar":{"stringUnit":{"state":"translated","value":"لا يتضمن عامل تصفية المراجعة هذا أي بطاقات بعد."}},"zh-Hans":{"stringUnit":{"state":"translated","value":"此复习筛选条件中还没有任何卡片。"}},"de":{"stringUnit":{"state":"translated","value":"Dieser Wiederholungsfilter enthält noch keine Karten."}},"hi":{"stringUnit":{"state":"translated","value":"इस समीक्षा फ़िल्टर में अभी कोई कार्ड शामिल नहीं है।"}},"ja":{"stringUnit":{"state":"translated","value":"この復習フィルタにはまだカードが含まれていません。"}},"ru":{"stringUnit":{"state":"translated","value":"Этот фильтр повторения пока не включает ни одной карточки."}},"es-MX":{"stringUnit":{"state":"translated","value":"Este filtro de repaso todavía no incluye ninguna tarjeta."}},"es-ES":{"stringUnit":{"state":"translated","value":"Este filtro de repaso todavía no incluye ninguna tarjeta."}}}},
    "Try a different search or clear filters.":{"extractionState":"manual","localizations":{"en":{"stringUnit":{"state":"translated","value":"Try a different search or clear filters."}},"ar":{"stringUnit":{"state":"translated","value":"جرّب بحثًا مختلفًا أو امسح عوامل التصفية."}},"zh-Hans":{"stringUnit":{"state":"translated","value":"请尝试其他搜索或清除筛选条件。"}},"de":{"stringUnit":{"state":"translated","value":"Probiere eine andere Suche aus oder lösche die Filter."}},"hi":{"stringUnit":{"state":"translated","value":"कोई दूसरा खोज शब्द आज़माएं या फ़िल्टर साफ़ करें।"}},"ja":{"stringUnit":{"state":"translated","value":"別の検索を試すか、フィルタをクリアしてください。"}},"ru":{"stringUnit":{"state":"translated","value":"Попробуйте другой поиск или сбросьте фильтры."}},"es-MX":{"stringUnit":{"state":"translated","value":"Prueba otra búsqueda o borra los filtros."}},"es-ES":{"stringUnit":{"state":"translated","value":"Prueba otra búsqueda o borra los filtros."}}}},
    "Try clearing filters.":{"extractionState":"manual","localizations":{"en":{"stringUnit":{"state":"translated","value":"Try clearing filters."}},"ar":{"stringUnit":{"state":"translated","value":"جرّب مسح عوامل التصفية."}},"zh-Hans":{"stringUnit":{"state":"translated","value":"试试清除筛选条件。"}},"de":{"stringUnit":{"state":"translated","value":"Versuche, die Filter zu löschen."}},"hi":{"stringUnit":{"state":"translated","value":"फ़िल्टर साफ़ करके देखें।"}},"ja":{"stringUnit":{"state":"translated","value":"フィルタをクリアしてみてください。"}},"ru":{"stringUnit":{"state":"translated","value":"Попробуйте сбросить фильтры."}},"es-MX":{"stringUnit":{"state":"translated","value":"Prueba a borrar los filtros."}},"es-ES":{"stringUnit":{"state":"translated","value":"Prueba a borrar los filtros."}}}},
    "You haven't created any cards yet.":{"extractionState":"manual","localizations":{"en":{"stringUnit":{"state":"translated","value":"You haven't created any cards yet."}},"ar":{"stringUnit":{"state":"translated","value":"لم تنشئ أي بطاقات بعد."}},"zh-Hans":{"stringUnit":{"state":"translated","value":"你还没有创建任何卡片。"}},"de":{"stringUnit":{"state":"translated","value":"Du hast noch keine Karten erstellt."}},"hi":{"stringUnit":{"state":"translated","value":"आपने अभी तक कोई कार्ड नहीं बनाया है।"}},"ja":{"stringUnit":{"state":"translated","value":"まだカードを作成していません。"}},"ru":{"stringUnit":{"state":"translated","value":"Вы еще не создали ни одной карточки."}},"es-MX":{"stringUnit":{"state":"translated","value":"Aún no has creado ninguna tarjeta."}},"es-ES":{"stringUnit":{"state":"translated","value":"Aún no has creado ninguna tarjeta."}}}},
    "You haven't created any cards yet. Add your first card to start studying.":{"extractionState":"manual","localizations":{"en":{"stringUnit":{"state":"translated","value":"You haven't created any cards yet. Add your first card to start studying."}},"ar":{"stringUnit":{"state":"translated","value":"لم تنشئ أي بطاقات بعد. أضف بطاقتك الأولى لبدء الدراسة."}},"zh-Hans":{"stringUnit":{"state":"translated","value":"你还没有创建任何卡片。添加第一张卡片即可开始学习。"}},"de":{"stringUnit":{"state":"translated","value":"Du hast noch keine Karten erstellt. Füge deine erste Karte hinzu, um mit dem Lernen zu beginnen."}},"hi":{"stringUnit":{"state":"translated","value":"आपने अभी तक कोई कार्ड नहीं बनाया है। पढ़ाई शुरू करने के लिए अपना पहला कार्ड जोड़ें।"}},"ja":{"stringUnit":{"state":"translated","value":"まだカードを作成していません。最初のカードを追加して学習を始めましょう。"}},"ru":{"stringUnit":{"state":"translated","value":"Вы еще не создали ни одной карточки. Добавьте первую карточку, чтобы начать учиться."}},"es-MX":{"stringUnit":{"state":"translated","value":"Aún no has creado ninguna tarjeta. Agrega tu primera tarjeta para empezar a estudiar."}},"es-ES":{"stringUnit":{"state":"translated","value":"Aún no has creado ninguna tarjeta. Añade tu primera tarjeta para empezar a estudiar."}}}},
    "You're all caught up for now. Come back later or add more cards.":{"extractionState":"manual","localizations":{"en":{"stringUnit":{"state":"translated","value":"You're all caught up for now. Come back later or add more cards."}},"ar":{"stringUnit":{"state":"translated","value":"لقد أنهيت كل ما عليك حاليًا. عُد لاحقًا أو أضف المزيد من البطاقات."}},"zh-Hans":{"stringUnit":{"state":"translated","value":"你目前已经全部复习完了。稍后再来，或添加更多卡片。"}},"de":{"stringUnit":{"state":"translated","value":"Du bist fürs Erste fertig. Komm später wieder oder füge weitere Karten hinzu."}},"hi":{"stringUnit":{"state":"translated","value":"फिलहाल आपने सब पूरा कर लिया है। बाद में वापस आएं या और कार्ड जोड़ें।"}},"ja":{"stringUnit":{"state":"translated","value":"今のところ、復習はすべて完了しています。後で戻るか、カードを追加してください。"}},"ru":{"stringUnit":{"state":"translated","value":"Сейчас вы все повторили. Вернитесь позже или добавьте еще карточки."}},"es-MX":{"stringUnit":{"state":"translated","value":"Por ahora ya estás al día. Vuelve más tarde o agrega más tarjetas."}},"es-ES":{"stringUnit":{"state":"translated","value":"Por ahora ya estás al día. Vuelve más tarde o añade más tarjetas."}}}},
