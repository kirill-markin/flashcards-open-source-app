    "Couldn't prepare audio for speech. Check your audio settings and try again.":{"extractionState":"manual","localizations":{"en":{"stringUnit":{"state":"translated","value":"Couldn't prepare audio for speech. Check your audio settings and try again."}},"ar":{"stringUnit":{"state":"translated","value":"تعذر تجهيز الصوت للنطق. تحقق من إعدادات الصوت وحاول مرة أخرى."}},"zh-Hans":{"stringUnit":{"state":"translated","value":"无法准备语音播放。请检查音频设置后重试。"}},"de":{"stringUnit":{"state":"translated","value":"Audio für die Sprachausgabe konnte nicht vorbereitet werden. Prüfe deine Audioeinstellungen und versuche es erneut."}},"hi":{"stringUnit":{"state":"translated","value":"बोलने के लिए ऑडियो तैयार नहीं किया जा सका। अपनी ऑडियो सेटिंग्स जांचें और फिर से कोशिश करें।"}},"ja":{"stringUnit":{"state":"translated","value":"読み上げ用の音声を準備できませんでした。オーディオ設定を確認して、もう一度お試しください。"}},"ru":{"stringUnit":{"state":"translated","value":"Не удалось подготовить звук для озвучивания. Проверьте настройки аудио и попробуйте снова."}},"es-MX":{"stringUnit":{"state":"translated","value":"No se pudo preparar el audio para la voz. Revisa la configuración de audio e inténtalo de nuevo."}},"es-ES":{"stringUnit":{"state":"translated","value":"No se pudo preparar el audio para la voz. Revisa la configuración de audio e inténtalo de nuevo."}}}},
